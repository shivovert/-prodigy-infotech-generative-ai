import random

def generate_markov(text, n=2):
    words = text.split()
    model = {}
    for i in range(len(words)-n):
        key = tuple(words[i:i+n])
        next_word = words[i+n]
        model.setdefault(key, []).append(next_word)
    return model

def generate_text(model, length=50):
    key = random.choice(list(model.keys()))
    result = list(key)
    for _ in range(length):
        next_words = model.get(key)
        if not next_words: break
        next_word = random.choice(next_words)
        result.append(next_word)
        key = tuple(result[-2:])
    return ' '.join(result)

